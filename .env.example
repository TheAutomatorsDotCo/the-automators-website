# Cloudflare Turnstile (bot protection)
# Sign up at https://dash.cloudflare.com > Turnstile > Add Site
# The site key is PUBLIC and safe to expose in client-side code.
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Cloudflare Turnstile secret key - SERVER ONLY, never use VITE_ prefix
# Used by the serverless function to verify challenge tokens.
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# n8n Webhook URL - SERVER ONLY, never use VITE_ prefix
# Create a Webhook trigger node in n8n and paste the production URL here.
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id

# n8n Webhook secret - SERVER ONLY
# Sent as the "x-webhook-token" header so your n8n workflow can verify the source.
# Set to any strong random string; add a Header Auth credential check in your n8n Webhook node.
N8N_WEBHOOK_SECRET=your_webhook_secret_here

# Discovery-call booking URL (optional override)
# The landing page uses https://meet.brevo.com/braam-raubenheimer/e-commerce-chatbot by default.
# Set this if you want to override the booking link without redeploying.
# VITE_BOOKING_URL=https://meet.brevo.com/braam-raubenheimer/e-commerce-chatbot
